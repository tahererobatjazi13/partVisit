<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="?attr/colorBackSurface">

    <com.partsystem.partvisitapp.core.utils.componenet.Header
        android:id="@+id/hfSync"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:drawableImgTwoHeader="@drawable/ic_back"
        app:isShowImgTwoHeader="true"
        app:isShowSeparatorHeader="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:textTitleHeader="@string/label_receive_update_information" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clSelectAll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/x_small_size"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/hfSync">

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbSelectAll"
            android:layout_width="@dimen/_20sdp"
            android:layout_height="@dimen/_20sdp"
            android:background="@drawable/checkbox_selector"
            android:button="@null"
            android:padding="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tvName"
            style="@style/LargeBoldTextStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/small_size"
            android:text="@string/label_select_all"
            android:textColor="@color/colorPrimary"
            android:textDirection="rtl"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/cbSelectAll"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSyncList"
        android:layout_width="match_parent"
        tools:itemCount="5"
        android:layout_marginTop="@dimen/medium_size"
        tools:listitem="@layout/item_sync_row"
        android:layout_height="0dp"
        android:layout_marginBottom="@dimen/medium_size"
        app:layout_constraintBottom_toTopOf="@+id/btnSync"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/clSelectAll" />

    <com.partsystem.partvisitapp.core.utils.componenet.BottomMain
        android:id="@+id/btnSync"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/medium_size"
        app:backColorBtnOne="@color/colorPrimary"
        app:badgeTextColorBtnOne="?attr/colorOnPrimary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:textBtnOne="@string/label_receive_update_information" />

</androidx.constraintlayout.widget.ConstraintLayout>